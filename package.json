{
  "name": "dysmaths",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node -e \"const path=require('path');const run=require(path.join(path.dirname(process.env.npm_package_json),'scripts','run-next.cjs'));run('predev-clean');\"",
    "dev": "node -e \"const path=require('path');const run=require(path.join(path.dirname(process.env.npm_package_json),'scripts','run-next.cjs'));run('dev');\"",
    "build": "node -e \"const path=require('path');const run=require(path.join(path.dirname(process.env.npm_package_json),'scripts','run-next.cjs'));run('build');\"",
    "start": "node -e \"const path=require('path');const run=require(path.join(path.dirname(process.env.npm_package_json),'scripts','run-next.cjs'));run('start');\"",
    "lint": "next lint"
  },
  "dependencies": {
    "@lexical/html": "^0.41.0",
    "@lexical/react": "^0.41.0",
    "@lexical/rich-text": "^0.41.0",
    "@lexical/selection": "^0.41.0",
    "@lexical/utils": "^0.41.0",
    "docx": "^9.5.1",
    "file-saver": "^2.0.5",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.0",
    "katex": "^0.16.22",
    "lexical": "^0.41.0",
    "mathlive": "^0.109.0",
    "next": "15.4.11",
    "next-intl": "^4.8.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/file-saver": "^2.0.7",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "typescript": "^5.8.2"
  }
}
